        local copyBtn=Instance.new("TextButton"); copyBtn.Size=UDim2.new(0,16,0,16); copyBtn.Position=UDim2.new(1,-19,0.5,-8)
        copyBtn.BackgroundColor3=Color3.fromRGB(30,80,30); copyBtn.Text="⊕"; copyBtn.TextColor3=Color3.new(1,1,1)
        copyBtn.Font=Enum.Font.GothamBold; copyBtn.TextSize=9; copyBtn.BorderSizePixel=0; copyBtn.Parent=row
        Instance.new("UICorner",copyBtn).CornerRadius=UDim.new(0,3)
        copyBtn.MouseButton1Click:Connect(function()
            local hrp=getHRP()
            if hrp then
                local p=hrp.Position
                local base=UserSettings[def.baseKey]
                UserSettings[def.offKey]={
                    r2(p.X-base[1]),
                    r2(p.Y-base[2]),
                    r2(p.Z-base[3])
                }
                for ai2=1,3 do
                    boxRefs[ai2].Text=tostring(UserSettings[def.offKey][ai2])
                end
                refreshWP(); saveSettings()
                if _G.waypointESPEnabled then buildESP() end
            end
        end)

        table.insert(allOffsetBoxes, {def=def, boxes=boxRefs})
        sY=sY+29
    end

    sY=sY+4
    local restoreBtn=Instance.new("TextButton"); restoreBtn.Size=UDim2.new(1,-6,0,24); restoreBtn.Position=UDim2.new(0,3,0,sY)
    restoreBtn.BackgroundColor3=Color3.fromRGB(120,20,20); restoreBtn.Text="RESTORE TO DEFAULT"
    restoreBtn.TextColor3=Color3.new(1,1,1); restoreBtn.Font=Enum.Font.GothamBlack; restoreBtn.TextSize=10
    restoreBtn.BorderSizePixel=0; restoreBtn.Parent=settingsPage
    Instance.new("UICorner",restoreBtn).CornerRadius=UDim.new(0,5)
    local rbs=Instance.new("UIStroke"); rbs.Color=Color3.fromRGB(255,60,60); rbs.Thickness=1; rbs.Parent=restoreBtn
    restoreBtn.MouseButton1Click:Connect(function()
        local newBases = {
            wpLeft1      = {-476.48, -6.28, 92.73},
            wpLeft2      = {-483.12, -4.95, 94.80},
            wpRight1     = {-476.16, -6.52, 25.62},
            wpRight2     = {-483.04, -5.09, 23.14},
            wpLeftPlay3  = {-476.5, -6.1,   7.5},
            wpRightPlay3 = {-476.2, -6.2, 113.5},
        }
        for k,v in pairs(newBases) do UserSettings[k]=v end
        local offKeys={"offLeft1","offLeft2","offRight1","offRight2","offLeftPlay3","offRightPlay3"}
        for _,k in ipairs(offKeys) do UserSettings[k]={0,0,0} end
        for _,entry in ipairs(allOffsetBoxes) do
            for ai=1,3 do entry.boxes[ai].Text="0" end
        end
        refreshWP(); saveSettings()
        if _G.waypointESPEnabled then buildESP() end
    end)
    sY=sY+28

    pages["settings"].height=sY+8
    if pages["settings"].frame then pages["settings"].frame.Size=UDim2.new(1,0,0,sY+8) end

    switchTab("main")

    -- ===== CIRCLES =====
    mainCircle=Instance.new("Frame"); mainCircle.Size=UDim2.new(0,52,0,52)
    mainCircle.BackgroundColor3=Color3.fromRGB(180,0,0); mainCircle.BorderSizePixel=0
    mainCircle.Active=true; mainCircle.Draggable=true; mainCircle.Parent=hubGui
    Instance.new("UICorner",mainCircle).CornerRadius=UDim.new(1,0)
    local csk=Instance.new("UIStroke"); csk.Color=Color3.fromRGB(255,50,50); csk.Thickness=2; csk.Transparency=0.5; csk.Parent=mainCircle
    local cTxt=Instance.new("TextLabel"); cTxt.Size=UDim2.new(1,0,1,0); cTxt.BackgroundTransparency=1
    cTxt.Text="VEX"; cTxt.TextColor3=Color3.new(1,1,1); cTxt.Font=Enum.Font.GothamBlack; cTxt.TextSize=11; cTxt.TextWrapped=true; cTxt.Parent=mainCircle
    table.insert(allCircles,mainCircle)
    local mp=UserSettings.pos_mainCircle; mainCircle.Position=UDim2.new(mp[1],mp[2],mp[3],mp[4])
    mainCircle.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then task.wait(); saveCirclePos("pos_mainCircle",mainCircle) end
    end)

    local dropLbl; dropCircle,dropLbl=makeCircle(hubGui,"DROP",Color3.fromRGB(180,0,0),Color3.fromRGB(255,50,50),UDim2.new(0.97,-66,0.81,-28),"pos_dropCircle")
    dropCircle.Visible=UserSettings.feat_drop; onClicked(dropCircle,function() if _G.dropEnabled then startWalkFling() end end)

    local lockLbl; lockCircle,lockLbl=makeCircle(hubGui,"LOCK",Color3.fromRGB(180,80,0),Color3.fromRGB(255,160,60),UDim2.new(0.97,-66,0.70,-28),"pos_lockCircle")
    lockCircle.Visible=UserSettings.feat_lockNearest
    onClicked(lockCircle,function()
        if not _G.lockNearestEnabled then return end
        if batAimbotOn then stopLockNearest(); lockLbl.Text="LOCK"; lockCircle.BackgroundColor3=Color3.fromRGB(180,80,0)
        else pauseAutoDuelUI(); startLockNearest(); lockLbl.Text="ON"; lockCircle.BackgroundColor3=Color3.fromRGB(0,130,30) end
    end)

    local tpDownLbl; tpDownCircle,tpDownLbl=makeCircle(hubGui,"TP\nDOWN",Color3.fromRGB(0,120,80),Color3.fromRGB(100,255,180),UDim2.new(0.97,-66,0.59,-28),"pos_tpDownCircle")
    tpDownCircle.Visible=UserSettings.feat_tpDown; onClicked(tpDownCircle,function() if _G.tpDownEnabled then doTPDown() end end)

    local duelLeftLbl; duelLeftCircle,duelLeftLbl=makeCircle(hubGui,"LEFT",Color3.fromRGB(0,100,180),Color3.fromRGB(80,180,255),UDim2.new(0.03,10,0.92,-28),"pos_duelLeftCircle")
    duelLeftCircle.Visible=UserSettings.feat_autoDuel

    local duelRightLbl; duelRightCircle,duelRightLbl=makeCircle(hubGui,"RIGHT",Color3.fromRGB(180,0,100),Color3.fromRGB(255,80,180),UDim2.new(0.03,10,0.81,-28),"pos_duelRightCircle")
    duelRightCircle.Visible=UserSettings.feat_autoDuel

    task.spawn(function()
        local t=0
        while hubGui and hubGui.Parent do
            t=t+RunService.RenderStepped:Wait()
            if duelLeftRunning then local pulse=0.5+0.5*math.sin(t*4); duelLeftCircle.BackgroundColor3=Color3.fromRGB(math.floor(pulse*40),math.floor(140+pulse*115),math.floor(180+pulse*75)) end
            if duelRightRunning then local pulse=0.5+0.5*math.sin(t*4); duelRightCircle.BackgroundColor3=Color3.fromRGB(math.floor(180+pulse*75),math.floor(pulse*40),math.floor(100+pulse*155)) end
        end
    end)

    onClicked(duelLeftCircle,function()
        if not _G.autoDuelEnabled then return end; pauseLock()
        if duelLeftRunning then stopStealPath(); duelLeftLbl.Text="LEFT"; duelLeftCircle.BackgroundColor3=Color3.fromRGB(0,100,180)
        else
            stopStealPath(); duelLeftRunning=true; duelRightRunning=false
            if duelRightLbl then duelRightLbl.Text="RIGHT" end; if duelRightCircle then duelRightCircle.BackgroundColor3=Color3.fromRGB(180,0,100) end
            duelLeftLbl.Text="ON"; startStealPath(getStealPath1,"left")
        end
    end)
    onClicked(duelRightCircle,function()
        if not _G.autoDuelEnabled then return end; pauseLock()
        if duelRightRunning then stopStealPath(); duelRightLbl.Text="RIGHT"; duelRightCircle.BackgroundColor3=Color3.fromRGB(180,0,100)
        else
            stopStealPath(); duelRightRunning=true; duelLeftRunning=false
            if duelLeftLbl then duelLeftLbl.Text="LEFT" end; if duelLeftCircle then duelLeftCircle.BackgroundColor3=Color3.fromRGB(0,100,180) end
            duelRightLbl.Text="ON"; startStealPath(getStealPath2,"right")
        end
    end)

    local guiVisible=true
    local function toggleVisibility()
        guiVisible=not guiVisible; mainWin.Visible=guiVisible
        mainCircle.BackgroundColor3=guiVisible and Color3.fromRGB(180,0,0) or Color3.fromRGB(60,0,0)
    end
    onClicked(mainCircle,toggleVisibility)
    UserInputService.InputBegan:Connect(function(i) if i.KeyCode==Enum.KeyCode.RightShift then toggleVisibility() end end)

    if UserSettings.lockUI then for _,c in ipairs(allCircles) do c.Draggable=false end end

    print("[VEX Duel] GUIs created")
end

createAllGUIs()

player.CharacterAdded:Connect(function()
    task.wait(1.2); loadSettings(); refreshWP()
end)

RunService.Heartbeat:Connect(function()
    if hubGui and hubGui.Parent==nil then
        hubGui.Parent=PlayerGui
    end
end)

print("[VEX Duel] Loaded v18.3")
