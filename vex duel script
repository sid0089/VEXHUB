local function buildESP()
    if espFolder then espFolder:Destroy() end
    espFolder = Instance.new("Folder"); espFolder.Name="VEXDuelWaypointESP"; espFolder.Parent=workspace
    espByLabel = {}
    for _, def in ipairs(ESP_DEFS) do
        local wpGroup = WP[def.wpGroup]; local wp = wpGroup and wpGroup[def.idx]; if not wp then continue end
        local part = Instance.new("Part"); part.Name="ESPBox_"..def.label; part.Size=Vector3.new(1.6,2.8,1.6)
        part.CFrame=CFrame.new(wp.pos); part.Anchored=true; part.CanCollide=false
        part.CanQuery=false; part.CanTouch=false; part.Transparency=1; part.Parent=espFolder
        local box=Instance.new("BoxHandleAdornment"); box.Adornee=part; box.Size=part.Size
        box.Color3=def.color; box.AlwaysOnTop=true; box.ZIndex=5; box.Transparency=0.4; box.Parent=part
        local sel=Instance.new("SelectionBox"); sel.Adornee=part; sel.Color3=def.color
        sel.LineThickness=0.05; sel.SurfaceTransparency=0.85; sel.Parent=part
        local bb=Instance.new("BillboardGui"); bb.Adornee=part; bb.Size=UDim2.new(0,60,0,16)
        bb.StudsOffset=Vector3.new(0,2,0); bb.AlwaysOnTop=true; bb.Parent=part
        local lbl=Instance.new("TextLabel",bb); lbl.Size=UDim2.new(1,0,1,0); lbl.BackgroundTransparency=1
        lbl.Text=def.label; lbl.TextColor3=def.color; lbl.Font=Enum.Font.GothamBold; lbl.TextSize=10
        lbl.TextStrokeTransparency=0; lbl.TextStrokeColor3=Color3.new(0,0,0)
        espByLabel[def.label]={part=part,box=box,lbl=lbl,sel=sel,def=def}
    end
    if espConn then espConn:Disconnect() end
    espConn=RunService.Heartbeat:Connect(function()
        if not _G.waypointESPEnabled or not espFolder or not espFolder.Parent then return end
        local t=tick(); local isLeft=espCurrentSide=="L"
        for _,entry in pairs(espByLabel) do
            local grp=entry.def.wpGroup
            local isLeftGroup=(grp=="Left" or grp=="LeftPlay")
            local shouldShow=(isLeft and isLeftGroup) or (not isLeft and not isLeftGroup)
            if not shouldShow then
                if entry.box then entry.box.Transparency=1 end
                if entry.sel then entry.sel.SurfaceTransparency=1; entry.sel.LineThickness=0 end
            else
                local wpG=WP[entry.def.wpGroup]; local wp=wpG and wpG[entry.def.idx]
                if wp then entry.part.CFrame=CFrame.new(wp.pos) end
                if entry.box then entry.box.Size=Vector3.new(1.6,2.8,1.6); entry.box.Transparency=0.25+0.3*math.abs(math.sin(t*1.8)) end
                if entry.sel then entry.sel.SurfaceTransparency=0.85; entry.sel.LineThickness=0.05 end
            end
        end
    end)
end

local function startWaypointESP() _G.waypointESPEnabled=true; buildESP() end
