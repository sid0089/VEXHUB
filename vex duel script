local function deepCopy(t)
    local copy = {}
    for k, v in pairs(t) do
        copy[k] = (type(v) == "table") and deepCopy(v) or v
    end
    return copy
end

local OFFSET_KEYS = {
    "offLeft1","offLeft2","offRight1","offRight2","offLeftPlay3","offRightPlay3"
}
local BASE_KEYS = {
    "wpLeft1","wpLeft2","wpRight1","wpRight2","wpLeftPlay3","wpRightPlay3"
}

local function loadSettings()
    UserSettings = deepCopy(DefaultSettings)
    pcall(function()
        if isfile and isfile(SAVE_FILE) then
            local raw = readfile(SAVE_FILE)
            local decoded = HttpService:JSONDecode(raw)
            for k, v in pairs(decoded) do
                if DefaultSettings[k] ~= nil then
                    if type(v) == "table" then
                        local cleaned = {}
                        for i, n in ipairs(v) do
                            cleaned[i] = type(n) == "number" and r2(n) or n
                        end
                        UserSettings[k] = cleaned
                    else
                        UserSettings[k] = v
                    end
                end
            end
        end
    end)
    for _, k in ipairs(OFFSET_KEYS) do
        UserSettings[k] = roundVec(UserSettings[k])
    end
    for _, k in ipairs(BASE_KEYS) do
        UserSettings[k] = roundVec(UserSettings[k])
    end
end

local function saveSettings()
    for _, k in ipairs(OFFSET_KEYS) do
        UserSettings[k] = roundVec(UserSettings[k])
    end
    for _, k in ipairs(BASE_KEYS) do
        UserSettings[k] = roundVec(UserSettings[k])
    end
    pcall(function()
        if writefile then
            writefile(SAVE_FILE, HttpService:JSONEncode(UserSettings))
        end
    end)
end

